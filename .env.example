# Copia este archivo como .env y completa con tus credenciales de Supabase.
# Solo usa la clave pública (anon / publishable). Nunca expongas la service_role key.
#
# Dónde encontrarlas:
# Supabase Dashboard → Project Settings → API
#   - Project URL     → VITE_SUPABASE_URL
#   - anon public     → VITE_SUPABASE_ANON_KEY (JWT que empieza con eyJ...)
#   - publishable key → VITE_SUPABASE_ANON_KEY (formato sb_publishable_...)

VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_tu-clave-o-eyJ...
